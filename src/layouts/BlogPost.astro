---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import BaseLayout from "./BaseLayout.astro";
import Container from "../components/Container.astro";
import MarkdownBody from "../components/MarkdownBody.astro";
import TableOfContents from '../components/TableOfContents.svelte';

interface Props {
	data: CollectionEntry<'blog'>['data'];
	body?: string;
	prevPost?: CollectionEntry<'blog'> | null;
	nextPost?: CollectionEntry<'blog'> | null;
}

const { data, body, prevPost, nextPost } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage } = data;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// 从文章内容中提取 H2 和 H3 标题
const headings: Array<{ id: string; text: string; level: number }> = [];
const idCountMap = new Map<string, number>(); // 用于跟踪每个 ID 出现的次数

if (body) {
	const headingRegex = /^(#+)\s+(.*?)(?:\s*{#([a-zA-Z0-9_-]+)})?$/gm;
	let match;
	while ((match = headingRegex.exec(body)) !== null) {
		const level = match[1].length;
		const text = match[2].trim();
		let id = match[3] || ''; // 尝试获取显式 ID

		if (!id) {
			// 生成基础 ID：将文本转换为小写，替换空格为连字符，移除非字母数字字符
			let baseId = text
				.toLowerCase()
				.replace(/\s+/g, '-')
				.replace(/[^a-z0-9\u4e00-\u9fa5-]/g, '');

			// 如果 ID 已存在，添加序号
			const count = idCountMap.get(baseId) || 0;
			idCountMap.set(baseId, count + 1);
			id = count > 0 ? `${baseId}-${count}` : baseId;
		}
		
		headings.push({ id, text, level });
	}
}
---

<BaseLayout>
	<BaseHead slot="head" title={title} description={description} image={heroImage} />
	<Header />
	<Container defaultPadding={true}>
		<div class="mb-8 grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-8">
			<!-- 文章主体 -->
			<article class="text-black dark:text-white">
				<h2 class="text-3xl font-bold leading-normal">{title}</h2>
				<div class="mt-4">
					<FormattedDate class="opacity-60" date={pubDate} />
					{updatedDate && <span class="opacity-60">(Last updated on <FormattedDate date={pubDate}/>)</span>}
				</div>
				<MarkdownBody class="mt-6">
					<slot />
				</MarkdownBody>
			</article>
			
			<!-- 右侧目录导航 -->
			<aside class="hidden lg:block">
				<TableOfContents {headings} client:load />
			</aside>
		</div>
		<!-- 上下篇导航 -->
		{(prevPost || nextPost) && (
			<nav class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-8 mb-8 text-black dark:text-white">
				{prevPost ? (
					<a
						href={`${base}/post/${prevPost.id}/`}
						class="group flex flex-col gap-1 p-4 rounded-xl border border-primary-200 dark:border-primary-900 bg-white/50 dark:bg-gray-950/50 backdrop-blur-sm hover:border-primary-400 dark:hover:border-primary-600 transition-colors"
					>
						<span class="text-xs opacity-60">← 上一篇</span>
						<span class="font-bold text-primary-600 dark:text-primary-400 group-hover:text-primary-400 dark:group-hover:text-primary-200 transition-colors line-clamp-2">{prevPost.data.title}</span>
					</a>
				) : <div />}
				{nextPost ? (
					<a
						href={`${base}/post/${nextPost.id}/`}
						class="group flex flex-col gap-1 p-4 rounded-xl border border-primary-200 dark:border-primary-900 bg-white/50 dark:bg-gray-950/50 backdrop-blur-sm hover:border-primary-400 dark:hover:border-primary-600 transition-colors"
					>
						<span class="text-xs opacity-60">下一篇 →</span>
						<span class="font-bold text-primary-600 dark:text-primary-400 group-hover:text-primary-400 dark:group-hover:text-primary-200 transition-colors line-clamp-2">{nextPost.data.title}</span>
					</a>
				) : <div />}
			</nav>
		)}
		<slot name="comment" />
	</Container>
	<Footer />
</BaseLayout>
