---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import Giscus from '../../components/Giscus.astro';
import {filterPosts} from "../../utils/misc";

export async function getStaticPaths() {
	const posts = filterPosts(await getCollection('blog'), {
		filterDraft: true,
		filterUnlisted: false,
	});
	return posts.map((post, index) => ({
		params: { slug: post.id },
		props: {
			...post,
			prevPost: posts[index + 1] ?? null,
			nextPost: posts[index - 1] ?? null,
		},
	}));
}
type Props = CollectionEntry<'blog'> & {
	prevPost: CollectionEntry<'blog'> | null;
	nextPost: CollectionEntry<'blog'> | null;
};

const { prevPost, nextPost, ...post } = Astro.props;
const { Content } = await render(post);
---

<BlogPost data={post.data} body={post.body} prevPost={prevPost} nextPost={nextPost}>
	<Content />
	<Giscus slot="comment" />
</BlogPost>
